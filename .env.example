# ---- Neo4j (Neo4j Desktop, local) ----
# NEVER commit the real .env. Copy this file to .env and fill the password.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# ---- Ollama (local) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# When true, the game runs with a deterministic in-process MockLLMService.
# No Ollama required. Recommended for demos and tests.
MOCK_LLM=false

# ---- CORS ----
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173
